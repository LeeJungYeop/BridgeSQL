# ===========================================
# Semantic Query Engine - Environment Config
# ===========================================
# 이 파일을 .env로 복사하여 사용하세요

# -------------------------------------------
# LLM Configuration (Gemini 2.0 Flash)
# -------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# -------------------------------------------
# Database Connection
# -------------------------------------------
# MySQL 연결 정보
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/database_name

# 또는 개별 설정
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=your_database

# -------------------------------------------
# Vector Store (ChromaDB)
# -------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=semantic_catalog

# -------------------------------------------
# Application Settings
# -------------------------------------------
LOG_LEVEL=INFO
SAMPLE_DATA_LIMIT=10
MAX_SQL_RETRY=3
